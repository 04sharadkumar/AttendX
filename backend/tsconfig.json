{
  "compilerOptions": {

    "types": ["node","express"],
    "target": "ES2020",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "skipLibCheck": true,

    "resolveJsonModule": true,

    
  },

  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}